    <link rel="canonical" href="https://thirdfloor.gr/" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://thirdfloor.gr/" />
    <meta property="og:title" content="Third Floor | Barber Shop Γαλάτσι Αθήνα" />
