      name="twitter:description"
      content="Third Floor κουρείο στο Γαλάτσι Αθήνα. Κούρεμα, περιποίηση γενειάδας & ξύρισμα. Κλείσε ραντεβού online — Σύρου 19 & Ελ. Βενιζέλου."
    />
    <meta
      name="twitter:image"
      content="https://thirdfloor.gr/images/hero.png"
    />

    <SchemaOrg />
    <script
      is:inline
      src="https://cdn.userway.org/widget.js"
