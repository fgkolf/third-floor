---
import Social from "./Social.astro";

const year = new Date().getFullYear();
---

<footer class="w-full text-white px-[8%] py-5 flex flex-col">
  <article class="flex gap-5 justify-between flex-wrap">
    <div class="flex flex-col gap-3">
      <h3 class="font-semibold branded-text">thirdfloor</h3>
      <p class="max-w-sm font-semibold">
        Feel free to give it another try, your persistence and determination
        will lead you to success.
      </p>
    </div>
    <div class="flex flex-col gap-3">
      <h3 class="branded-text">Company</h3>
      <span>Home</span>
      <span>Privacy Policy</span>
      <span>About us</span>
    </div>
    <div class="flex flex-col gap-3">
      <h3 class="branded-text">Contact</h3>
      <div class="flex gap-3">
        <Social />
      </div>
    </div>
  </article>
  <article class="flex align-end">
    <div class="text-sm">
      <span>thirdfloor</span>
      <span>&copy;</span>
      <span>{year}</span>
    </div>
  </article>
  <span class="lights top-1/2 right-1/8"></span>
</footer>

<style>
  footer {
    position: relative;
    backdrop-filter: blur(0px) saturate(100%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    background-color: rgba(0, 0, 0, 0.2);
  }
</style>
