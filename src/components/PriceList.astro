---
const priceList = [
  {
    service: "Regular Haircut",
    description: "A great hair cut is the best accessory a man can have",
    price: "20€",
  },
  {
    service: "Beard Trim",
    description: "We bring the difference that makes you real",
    price: "7€",
  },
  {
    service: "Royal Shave",
    description: "Our three-step signature shave",
    price: "10€",
  },
  {
    service: "Haircut + Beard Trim",
    description: "Beard or Shave, we bring the difference that makes you real",
    price: "20€",
  },
  {
    service: "Haircut + Royal Shave",
    description: "Our exceptional secrets all together for you",
    price: "25€",
  },
];
---

<h2 class="text-4xl font-semibold text-center mb-12 branded-text">
  Price list
</h2>
<ul class="grid md:grid-cols-2 gap-16">
  {
    priceList.map(({ service, description, price }) => (
      <li class="flex pb-4 border-b-1">
        <div class="flex flex-col gap-4 w-full">
          <h3 class="text-2xl font-bold">{service}</h3>
          <span class="italic text-sm">{description}</span>
        </div>
        <div class="text-2xl font-bold pl-24 branded-text">{price}</div>
      </li>
    ))
  }
</ul>
<span class="lights top-1/2 left-1/3"></span>
