---
const priceList = [
  {
    service: "Haircut",
    price: "15€",
  },
  {
    service: "Beard Trim",
    price: "5€",
  },
  {
    service: "Shave",
    price: "10€",
  },
  {
    service: "Cut & Beard",
    price: "18€",
  },
  {
    service: "Cut & Shave",
    price: "22€",
  },
];
---

<h2 class="text-4xl font-semibold text-center mb-12 branded-text">MENU</h2>
<ul class="grid md:grid-cols-2 gap-16">
  {
    priceList.map(({ service, description, price }) => (
      <li class="flex pb-4 border-b-1">
        <div class="flex flex-col gap-4 w-full">
          <h3 class="text-xl font-bold">{service}</h3>
        </div>
        <div class="text-2xl font-bold pl-24 branded-text">{price}</div>
      </li>
    ))
  }
</ul>
<span class="lights top-1/2 left-1/3"></span>
